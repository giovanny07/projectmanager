# ── Config ────────────────────────────────────────────────────────────
msgid "Configuration"
msgstr "Configuración"

msgid "Configuration saved successfully."
msgstr "Configuración guardada correctamente."

# ── Module names ──────────────────────────────────────────────────────
msgid "Dependencies module is not enabled."
msgstr "El módulo de dependencias no está habilitado."

# ── TaskDependency — tab ──────────────────────────────────────────────
msgid "Task dependency"
msgid_plural "Task dependencies"
msgstr[0] "Dependencia de tarea"
msgstr[1] "Dependencias de tareas"

msgid "Dependencies"
msgstr "Dependencias"

# ── Dependency types ──────────────────────────────────────────────────
msgid "Finish-to-Start (FS)"
msgstr "Fin a Inicio (FS)"

msgid "Start-to-Start (SS)"
msgstr "Inicio a Inicio (SS)"

msgid "Finish-to-Finish (FF)"
msgstr "Fin a Fin (FF)"

msgid "Start-to-Finish (SF)"
msgstr "Inicio a Fin (SF)"

# ── Validation errors ─────────────────────────────────────────────────
msgid "A task cannot depend on itself."
msgstr "Una tarea no puede depender de sí misma."

msgid "This dependency would create a cycle in the project schedule."
msgstr "Esta dependencia crearía un ciclo en el cronograma del proyecto."

# ── Cascade engine ────────────────────────────────────────────────────
msgid "Cycle detected in project dependencies. Cascade aborted."
msgstr "Se detectó un ciclo en las dependencias del proyecto. Cascada cancelada."

msgid "ProjectManager: rescheduled +%d day(s) by cascade from task #%d"
msgstr "ProjectManager: replanificada +%d día(s) por cascada desde tarea #%d"

msgid "%d task rescheduled."
msgid_plural "%d tasks rescheduled."
msgstr[0] "%d tarea replanificada."
msgstr[1] "%d tareas replanificadas."

# ── Cascade complete message ──────────────────────────────────────────
msgid "Cascade complete: %d task rescheduled."
msgid_plural "Cascade complete: %d tasks rescheduled."
msgstr[0] "Cascada completada: %d tarea replanificada."
msgstr[1] "Cascada completada: %d tareas replanificadas."

# ── Twig template ─────────────────────────────────────────────────────
msgid "Task dependencies"
msgstr "Dependencias de tareas"

msgid "Recalculate all project dates based on dependencies"
msgstr "Recalcula todas las fechas del proyecto según las dependencias"

msgid "Force cascade recalculation"
msgstr "Forzar recálculo en cascada"

msgid "Automatic cascade is disabled. Use the button above to recalculate manually."
msgstr "La cascada automática está desactivada. Use el botón de arriba para recalcular manualmente."

msgid "Predecessors"
msgstr "Predecesoras"

msgid "No predecessors — this task can start freely."
msgstr "Sin predecesoras — esta tarea puede iniciar libremente."

msgid "Successors"
msgstr "Sucesoras"

msgid "No successors — this task does not block any other."
msgstr "Sin sucesoras — esta tarea no bloquea a ninguna otra."

msgid "Task"
msgstr "Tarea"

msgid "Type"
msgstr "Tipo"

msgid "Lag"
msgstr "Lag"

msgid "Plan end"
msgstr "Fin planificado"

msgid "Plan start"
msgstr "Inicio planificado"

msgid "Overdue predecessor"
msgstr "Predecesora vencida"

msgid "Remove this dependency?"
msgstr "¿Eliminar esta dependencia?"

msgid "Add dependency"
msgstr "Agregar dependencia"

msgid "Predecessor task"
msgstr "Tarea predecesora"

msgid "Loading..."
msgstr "Cargando..."

msgid "Lag (days)"
msgstr "Lag (días)"

msgid "Add"
msgstr "Agregar"

msgid "— Select task —"
msgstr "— Seleccionar tarea —"

msgid "No other tasks in this project"
msgstr "No hay otras tareas en este proyecto"

msgid "Error loading tasks"
msgstr "Error cargando tareas"

# ── Baseline ──────────────────────────────────────────────────────────
msgid "Baseline"
msgid_plural "Baselines"
msgstr[0] "Línea base"
msgstr[1] "Líneas base"

msgid "Schedule baseline"
msgstr "Línea base del cronograma"

msgid "Set baseline"
msgstr "Fijar línea base"

msgid "Re-set baseline"
msgstr "Re-fijar línea base"

msgid "This will overwrite the existing baseline for this project. Continue?"
msgstr "Esto sobreescribirá la línea base existente de este proyecto. ¿Continuar?"

msgid "No baseline set yet for this project."
msgstr "Este proyecto aún no tiene línea base."

msgid "This project has no tasks yet."
msgstr "Este proyecto aún no tiene tareas."

msgid "Baseline start"
msgstr "Inicio línea base"

msgid "Baseline end"
msgstr "Fin línea base"

msgid "Variance (days)"
msgstr "Varianza (días)"

msgid "On time"
msgstr "A tiempo"

msgid "Baseline set for %d task."
msgid_plural "Baseline set for %d tasks."
msgstr[0] "Línea base fijada para %d tarea."
msgstr[1] "Línea base fijada para %d tareas."

msgid "%d task skipped (no planned dates yet)."
msgid_plural "%d tasks skipped (no planned dates yet)."
msgstr[0] "%d tarea omitida (sin fechas planificadas aún)."
msgstr[1] "%d tareas omitidas (sin fechas planificadas aún)."

# ── Real dependency blocking ────────────────────────────────────────────
msgid "Block tasks with unmet dependencies"
msgstr "Bloquear tareas con dependencias incumplidas"

msgid "Prevent starting/finishing a task until its predecessors satisfy the FS/SS/FF/SF dependency, instead of only warning."
msgstr "Evita iniciar/terminar una tarea hasta que sus predecesoras cumplan la dependencia FS/SS/FF/SF, en vez de solo advertir."

msgid "Cannot save: predecessor \"%1$s\" does not satisfy the %2$s dependency yet."
msgstr "No se puede guardar: la predecesora \"%1$s\" aún no cumple la dependencia %2$s."

# ── Milestones ────────────────────────────────────────────────────────
msgid "Milestone"
msgstr "Hito"

# ── Critical path ─────────────────────────────────────────────────────
msgid "Critical path"
msgstr "Ruta crítica"

msgid "Tasks with zero float (highlighted) determine the project's overall duration — any delay on them delays the whole project."
msgstr "Las tareas con holgura cero (resaltadas) determinan la duración total del proyecto — cualquier atraso en ellas atrasa todo el proyecto."

msgid "Early start"
msgstr "Inicio temprano"

msgid "Early finish"
msgstr "Fin temprano"

msgid "Late start"
msgstr "Inicio tardío"

msgid "Late finish"
msgstr "Fin tardío"

msgid "Float (days)"
msgstr "Holgura (días)"

msgid "Critical"
msgstr "Crítica"
